{
  "version": "1.0.0",
  "brand": "良禽佳木",
  "skill_name": "良禽品牌体",
  "primary_input": "brand_brief",
  "accepted_inputs": {
    "brand_brief": {
      "required": true,
      "purpose": "锁定品牌定位、目标用户、语气、服务方式和页面目标，是一切蓝图生成的起点。",
      "required_fields": [
        "brand_positioning",
        "target_audience",
        "tone_keywords",
        "service_model",
        "page_goal"
      ]
    },
    "product_data": {
      "required": false,
      "purpose": "给产品详情页和首页重点产品区提供事实依据，避免空泛叙事。",
      "required_fields_when_present": [
        "product_name",
        "materials",
        "dimensions",
        "craft_notes",
        "usage_scene"
      ]
    },
    "reference_pages": {
      "required": false,
      "purpose": "只用于校准结构节奏、图文编排和信息层级，不用于直接复刻视觉或文案。",
      "accepted_types": [
        "url",
        "text_summary",
        "image_reference"
      ],
      "extract_only": [
        "composition_logic",
        "section_pacing",
        "content_hierarchy"
      ],
      "forbidden_to_copy": [
        "brand_identity_elements",
        "headline_phrasing",
        "signature_interactions",
        "logo_or_marks"
      ]
    }
  },
  "input_media_policy": {
    "default_mode": "text_first",
    "image_role": "auxiliary_only",
    "notes": [
      "品牌 brief 和产品资料以文字为主。",
      "图片只用于补充材质、比例、空间气质判断，不作为唯一依据。",
      "最终视觉成品所需的 logo 与品牌标志，必须从 `protocols/brand-assets.zh-CN.json` 声明的真实资产中读取。"
    ]
  },
  "request_normalization": {
    "first_output": "structured_spec_only",
    "supported_spec_types": [
      "homepage_blueprint",
      "product_detail_blueprint",
      "visual_delivery_spec"
    ],
    "channel_policy": "channel_adapts_delivery_not_brand",
    "visual_request_triggers": [
      "图片",
      "长图",
      "海报",
      "视觉稿",
      "封面图",
      "报价卡图",
      "社媒卡片",
      "图标方案",
      "icon 方案"
    ],
    "rules": [
      "所有良禽视觉类请求，默认先收敛到结构化 spec，再按渠道适配渲染。",
      "如果同一句请求同时包含产品、材质、报价等信息词，但交付目标是图片、页面、长图、卡片或视觉稿，仍应优先路由到良禽品牌体。",
      "渠道变化只影响信息密度、画幅、交付形式，不改变品牌真源。",
      "如果图标精度和细节工艺无法稳定成立，优先减少或取消，不得自由发明另一套审美。",
      "如果要直接输出最终视觉成品，必须先确认真实 logo 资产可读；否则停止在结构化 spec。"
    ]
  },
  "fallback_rules": [
    {
      "condition": "missing_brand_brief",
      "action": "stop_final_blueprint",
      "reason": "缺少品牌 brief 时，无法稳定判断良禽佳木语气与页面目标。"
    },
    {
      "condition": "missing_product_data",
      "action": "allow_low_detail_blueprint",
      "reason": "可以先输出结构骨架，但不得臆造产品事实。"
    },
    {
      "condition": "missing_reference_pages",
      "action": "fallback_to_foundation_dna",
      "reason": "直接使用良禽佳木默认品牌边界和模块优先级。"
    },
    {
      "condition": "visual_request_without_structured_spec",
      "action": "generate_structured_spec_first",
      "reason": "良禽视觉类请求优先先生成受 DESIGN.md 约束的结构化 spec，再做渠道适配。"
    },
    {
      "condition": "final_visual_without_logo_asset",
      "action": "stop_final_visual_delivery",
      "reason": "未读取到真实 logo 资产时，不允许直接产出页面、图片、长图、卡片等最终视觉成品。"
    }
  ]
}
