{
  "version": "1.0.0",
  "brand": "良禽佳木",
  "source_of_truth": "assets/brand/asset-manifest.zh-CN.json",
  "mirror_role": "openclaw_adapter_protocol_mirror",
  "package_role": "openclaw_adapter_brand_assets_protocol_mirror",
  "adapter_scope": "OpenClaw 协议镜像可补充适配器执行语境，但不得改变根层资产清单与阻断规则。",
  "purpose": "声明良禽品牌体在 OpenClaw 运行时必须可读取的品牌识别资产，避免视觉交付退化成纯文字品牌名或误判 logo 缺失。",
  "consumption_tier": "tier_2",
  "required_runtime_assets": [
    {
      "id": "logo_horizontal_svg",
      "type": "logo",
      "role": "primary_header_mark",
      "preferred_format": "svg",
      "path": "assets/brand/liangqinjiamu-logo-horizontal.svg",
      "fallback_paths": [
        "assets/brand/liangqinjiamu-logo-horizontal.png"
      ],
      "usage_rules": [
        "优先用于页头、页尾、品牌签名区与横向品牌落款。",
        "禁止拉伸、描边、加浮雕、加发光或覆在高噪声背景上。",
        "可使用 Brand Asset 色或原始文件，不得擅自重绘字形。"
      ]
    },
    {
      "id": "logo_vertical_svg",
      "type": "logo",
      "role": "square_or_editorial_mark",
      "preferred_format": "svg",
      "path": "assets/brand/liangqinjiamu-logo-vertical.svg",
      "fallback_paths": [
        "assets/brand/liangqinjiamu-logo-vertical.png"
      ],
      "usage_rules": [
        "仅用于竖版品牌页、封面或更适合纵向识别的品牌签名场景。",
        "禁止替代横向主标在常规导航中的默认位置。"
      ]
    }
  ],
  "delivery_guardrails": {
    "final_visual_requires_logo_asset": true,
    "allowed_without_logo_asset": [
      "structured_spec_only"
    ],
    "blocked_outputs_when_missing": [
      "page_visual",
      "hero_image",
      "long_image",
      "multi_card_set"
    ],
    "missing_asset_action": "stop_final_delivery_and_report_missing_logo_asset",
    "missing_asset_message": "未读取到真实 logo 资产时，只允许输出受 DESIGN.md 约束的结构化 spec，不允许直接产出最终视觉成品。"
  },
  "icon_relationship": {
    "policy": "logo 优先级高于装饰图标。图标精度不足时可以减少或取消，但品牌标志不得被弱化成纯文本替身。"
  },
  "adapter_notes": {
    "cross_tool_role": "为 Tier 2 及以上消费层提供稳定品牌资产约束。",
    "missing_asset_default": "无真实 logo 资产时停在结构化 spec，不直出成品。"
  }
}
