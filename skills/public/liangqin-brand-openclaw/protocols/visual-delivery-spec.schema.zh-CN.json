{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "liangqin-brand-body/visual-delivery-spec.schema.zh-CN.json",
  "title": "良禽佳木视觉交付 Spec Schema",
  "type": "object",
  "required": [
    "page_type",
    "delivery_goal",
    "asset_form",
    "target_audience",
    "delivery_context",
    "primary_message",
    "information_priority",
    "layout_blocks",
    "visual_system",
    "image_strategy",
    "icon_strategy",
    "copy_tone",
    "brand_constraints",
    "surface_contract_summary",
    "asset_readiness",
    "handoff_rules",
    "handoff_state"
  ],
  "properties": {
    "page_type": {
      "const": "visual_delivery_spec"
    },
    "delivery_goal": {
      "type": "string"
    },
    "asset_form": {
      "type": "string",
      "enum": [
        "poster",
        "long_image",
        "quote_card",
        "social_cover",
        "page_visual",
        "hero_image",
        "multi_card_set",
        "icon_direction"
      ]
    },
    "target_audience": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "delivery_context": {
      "type": "object",
      "required": [
        "context_status",
        "selected_surface",
        "surface_reason",
        "material_readiness"
      ],
      "properties": {
        "context_status": {
          "type": "string",
          "enum": [
            "complete",
            "partial",
            "blocked"
          ]
        },
        "selected_surface": {
          "type": "string"
        },
        "surface_reason": {
          "type": "string"
        },
        "material_readiness": {
          "type": "string"
        },
        "variation_mode": {
          "type": "string"
        }
      }
    },
    "primary_message": {
      "type": "string"
    },
    "information_priority": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string"
      }
    },
    "layout_blocks": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "role",
          "content_requirements",
          "emphasis_rule"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "content_requirements": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "emphasis_rule": {
            "type": "string"
          },
          "density_note": {
            "type": "string"
          }
        }
      }
    },
    "visual_system": {
      "type": "object",
      "required": [
        "composition_rule",
        "background_strategy",
        "typography_direction",
        "color_strategy"
      ],
      "properties": {
        "composition_rule": {
          "type": "string"
        },
        "background_strategy": {
          "type": "string"
        },
        "typography_direction": {
          "type": "string"
        },
        "color_strategy": {
          "type": "string"
        },
        "material_expression": {
          "type": "string"
        }
      }
    },
    "image_strategy": {
      "type": "object",
      "required": [
        "image_role",
        "must_show",
        "forbidden"
      ],
      "properties": {
        "image_role": {
          "type": "string"
        },
        "must_show": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "icon_strategy": {
      "type": "object",
      "required": [
        "policy",
        "stroke_rule",
        "fallback_rule"
      ],
      "properties": {
        "policy": {
          "type": "string"
        },
        "stroke_rule": {
          "type": "string"
        },
        "fallback_rule": {
          "type": "string"
        }
      }
    },
    "copy_tone": {
      "type": "object",
      "required": [
        "headline_rule",
        "body_rule",
        "cta_rule"
      ],
      "properties": {
        "headline_rule": {
          "type": "string"
        },
        "body_rule": {
          "type": "string"
        },
        "cta_rule": {
          "type": "string"
        }
      }
    },
    "brand_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 4
    },
    "surface_contract_summary": {
      "type": "object",
      "required": [
        "canvas_format",
        "interaction_model",
        "export_formats",
        "verification_focus"
      ],
      "properties": {
        "canvas_format": {
          "type": "string"
        },
        "interaction_model": {
          "type": "string"
        },
        "export_formats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "verification_focus": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          }
        },
        "offline_expectation": {
          "type": "string"
        }
      }
    },
    "asset_readiness": {
      "type": "object",
      "required": [
        "logo_status",
        "imagery_status",
        "icon_status",
        "fact_status",
        "fallback_action"
      ],
      "properties": {
        "logo_status": {
          "type": "string",
          "enum": [
            "ready",
            "missing",
            "not_needed"
          ]
        },
        "imagery_status": {
          "type": "string",
          "enum": [
            "ready",
            "partial",
            "missing",
            "not_needed"
          ]
        },
        "icon_status": {
          "type": "string",
          "enum": [
            "ready",
            "partial",
            "missing",
            "not_needed"
          ]
        },
        "fact_status": {
          "type": "string",
          "enum": [
            "ready",
            "partial",
            "missing"
          ]
        },
        "fallback_action": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "handoff_rules": {
      "type": "object",
      "required": [
        "render_after_spec",
        "downstream_inputs",
        "fidelity_fail_action"
      ],
      "properties": {
        "render_after_spec": {
          "const": true
        },
        "downstream_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2
        },
        "fidelity_fail_action": {
          "type": "string"
        }
      }
    },
    "handoff_state": {
      "type": "object",
      "required": [
        "current_stage",
        "can_render_final",
        "next_action"
      ],
      "properties": {
        "current_stage": {
          "type": "string",
          "enum": [
            "structured_spec",
            "visual_draft",
            "prototype",
            "final_delivery",
            "blocked"
          ]
        },
        "can_render_final": {
          "type": "boolean"
        },
        "next_action": {
          "type": "string"
        },
        "blocker_if_any": {
          "type": "string"
        }
      }
    }
  }
}
